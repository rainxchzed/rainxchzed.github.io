---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

// Group posts by year for a nicer listing
const byYear = new Map<number, typeof posts>();
for (const p of posts) {
  const year = p.data.date.getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(p);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<BaseLayout title="posts — rainxchzed" description="Writing about Android, Kotlin Multiplatform, Compose, and the occasional cat.">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-12 md:py-16">
    <header class="mb-12 animate-fade-up">
      <h1 class="font-serif text-4xl md:text-5xl font-semibold tracking-tight">posts</h1>
      <p class="mt-3 text-muted">Thoughts on Android, KMP, Compose, and whatever else I'm deep in.</p>
    </header>

    {posts.length === 0 ? (
      <p class="text-muted italic">No posts yet — soon!</p>
    ) : (
      <div class="space-y-12">
        {years.map((year) => (
          <section class="scroll-reveal" style={`transition-delay: ${years.indexOf(year) * 100}ms`}>
            <h2 class="font-serif text-xl text-muted mb-4">{year}</h2>
            <div class="grid gap-3">
              {byYear.get(year)!.map((post) => (
                <PostCard
                  title={post.data.title}
                  description={post.data.description}
                  date={post.data.date}
                  href={`/posts/${post.id}`}
                />
              ))}
            </div>
          </section>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
