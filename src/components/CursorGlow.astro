---
/**
 * CursorGlow — a subtle ambient glow that follows the cursor.
 * Hidden on touch/mobile devices and when prefers-reduced-motion is active.
 * Reinitializes on view transitions via astro:page-load.
 */
---

<div id="cursor-glow" aria-hidden="true"></div>

<style>
  #cursor-glow {
    position: fixed;
    top: 0;
    left: 0;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    opacity: 0;
    background: radial-gradient(
      circle,
      rgb(var(--accent) / 0.05) 0%,
      transparent 70%
    );
    transform: translate(-50%, -50%);
    will-change: transform;
    transition: opacity 0.3s ease;
  }

  :global(.dark) #cursor-glow {
    background: radial-gradient(
      circle,
      rgb(var(--accent) / 0.1) 0%,
      transparent 70%
    );
  }
</style>

<script>
  function initCursorGlow() {
    const glow = document.getElementById("cursor-glow");
    if (!glow) return;

    // Hide on touch/mobile devices
    const isTouch =
      "ontouchstart" in window ||
      window.matchMedia("(hover: none)").matches;
    if (isTouch) {
      glow.style.display = "none";
      return;
    }

    // Respect prefers-reduced-motion
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    );
    if (prefersReducedMotion.matches) {
      glow.style.display = "none";
      return;
    }

    // Listen for changes to reduced motion preference
    prefersReducedMotion.addEventListener("change", (e) => {
      glow.style.display = e.matches ? "none" : "";
      if (e.matches) {
        glow.style.opacity = "0";
      }
    });

    let mouseX = 0;
    let mouseY = 0;
    let currentX = 0;
    let currentY = 0;
    let isVisible = false;
    let rafId: number | null = null;

    const LERP_FACTOR = 0.12;

    function onMouseMove(e: MouseEvent) {
      mouseX = e.clientX;
      mouseY = e.clientY;

      if (!isVisible) {
        // Snap to initial position so the glow doesn't slide in from (0,0)
        currentX = mouseX;
        currentY = mouseY;
        isVisible = true;
        glow.style.opacity = "1";
      }
    }

    function onMouseLeave() {
      isVisible = false;
      glow.style.opacity = "0";
    }

    function animate() {
      // Lerp toward the target position
      currentX += (mouseX - currentX) * LERP_FACTOR;
      currentY += (mouseY - currentY) * LERP_FACTOR;

      glow.style.transform = `translate(calc(${currentX}px - 50%), calc(${currentY}px - 50%))`;

      rafId = requestAnimationFrame(animate);
    }

    document.addEventListener("mousemove", onMouseMove);
    document.addEventListener("mouseleave", onMouseLeave);
    rafId = requestAnimationFrame(animate);

    // Cleanup function for view transitions
    return () => {
      document.removeEventListener("mousemove", onMouseMove);
      document.removeEventListener("mouseleave", onMouseLeave);
      if (rafId !== null) {
        cancelAnimationFrame(rafId);
      }
    };
  }

  let cleanup: (() => void) | undefined;

  document.addEventListener("astro:page-load", () => {
    if (cleanup) cleanup();
    cleanup = initCursorGlow() ?? undefined;
  });
</script>
