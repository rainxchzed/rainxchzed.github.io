---
const projects = [
  {
    name: 'GitHub-Store',
    description:
      'An open-source app store for GitHub releases. Multi-platform — Android, Windows, macOS, Linux — built with Kotlin and Compose Multiplatform.',
    stars: '11.4k',
    href: 'https://github.com/rainxchzed/GitHub-Store',
    tags: ['Kotlin', 'Compose Multiplatform'],
  },
  {
    name: 'RikkaUi',
    description:
      'A design system and component library for Jetpack Compose, inspired by shadcn/ui.',
    stars: '74',
    href: 'https://github.com/rainxchzed/RikkaUi',
    tags: ['Jetpack Compose', 'Design System'],
  },
  {
    name: 'RikkaIcons',
    description: 'A semantic icon library for Compose Multiplatform.',
    stars: '9',
    href: 'https://github.com/rainxchzed/RikkaIcons',
    tags: ['Compose Multiplatform', 'Icons'],
  },
];
---

<section class="py-12">
  <h2 class="font-serif text-2xl font-semibold mb-6">projects</h2>

  <div class="grid gap-4">
    {projects.map((p, i) => (
      <a
        href={p.href}
        target="_blank"
        rel="noopener noreferrer"
        class="scroll-reveal card-tilt card-shine group block rounded-xl border border-default bg-elevated p-5 transition-all duration-300 hover:border-accent"
        style={`transition-delay: ${i * 100}ms`}
      >
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0 flex-1">
            <h3 class="font-medium text-fg group-hover:text-accent transition-colors">
              {p.name}
            </h3>
            <p class="mt-1.5 text-sm text-muted leading-relaxed">{p.description}</p>
            <div class="mt-3 flex flex-wrap gap-1.5">
              {p.tags.map((t) => (
                <span class="tag-interactive inline-block text-xs text-muted bg-accent-soft px-2 py-0.5 rounded-full">
                  {t}
                </span>
              ))}
            </div>
          </div>
          <div class="shrink-0 flex items-center gap-1 text-xs text-muted">
            <svg class="star-icon h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2l2.9 6.1 6.6.9-4.8 4.6 1.2 6.6L12 17.3l-5.9 3 1.2-6.6L2.5 9l6.6-.9z" />
            </svg>
            {p.stars}
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<script>
  function initScrollReveal() {
    const elements = document.querySelectorAll('.scroll-reveal:not(.revealed)');

    if (!elements.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.classList.add('revealed');
            observer.unobserve(el);
          }
        }
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' },
    );

    for (const el of elements) {
      observer.observe(el);
    }
  }

  // Init on first load
  initScrollReveal();

  // Re-init after view transitions (handles astro:page-load for ClientRouter)
  document.addEventListener('astro:page-load', initScrollReveal);
</script>
