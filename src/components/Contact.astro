---
const links = [
  {
    label: 'GitHub',
    href: 'https://github.com/rainxchzed',
    handle: '@rainxchzed',
    icon: 'github',
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/rainxchzed',
    handle: 'in/rainxchzed',
    icon: 'linkedin',
  },
  {
    label: 'Email',
    href: 'mailto:rainxch.dev@gmail.com',
    handle: 'rainxch.dev@gmail.com',
    icon: 'mail',
  },
];
---

<section class="py-12">
  <h2 class="font-serif text-2xl font-semibold mb-6">get in touch</h2>
  <p class="text-muted mb-6 max-w-prose">
    Open to collaboration, open-source contributions, and interesting Android / KMP conversations.
  </p>
  <ul class="grid gap-3">
    {links.map(({ label, href, handle, icon }) => (
      <li>
        <a
          href={href}
          class="group flex items-center justify-between gap-4 rounded-lg border border-default bg-elevated px-4 py-3 transition-all duration-300 hover:border-accent hover:-translate-y-0.5"
        >
          <div class="flex items-center gap-3 min-w-0">
            <span class="text-muted group-hover:text-accent transition-colors">
              {icon === 'github' && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 .5A12 12 0 0 0 0 12.5a12 12 0 0 0 8.2 11.4c.6.1.8-.3.8-.6v-2.1c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.8.1-.8.1-.8 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.3 3.6 1 .1-.8.4-1.3.8-1.7-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.3-3.3-.1-.3-.6-1.6.1-3.3 0 0 1-.3 3.3 1.3a11.5 11.5 0 0 1 6 0c2.3-1.6 3.3-1.3 3.3-1.3.7 1.7.3 3 .1 3.3.8.9 1.3 2 1.3 3.3 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.3v3.4c0 .3.2.7.8.6A12 12 0 0 0 24 12.5a12 12 0 0 0-12-12z" />
                </svg>
              )}
              {icon === 'linkedin' && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5V9h3v10zM6.5 7.5A1.75 1.75 0 1 1 6.5 4a1.75 1.75 0 0 1 0 3.5zM19 19h-3v-4.8c0-1.1 0-2.6-1.6-2.6s-1.8 1.2-1.8 2.5V19h-3V9h2.9v1.4h0A3.2 3.2 0 0 1 15.3 8.8c3 0 3.7 2 3.7 4.6V19z" />
                </svg>
              )}
              {icon === 'mail' && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="4" width="20" height="16" rx="2" />
                  <path d="m22 7-10 7L2 7" />
                </svg>
              )}
            </span>
            <span class="text-sm font-medium text-fg">{label}</span>
          </div>
          <span class="text-sm text-muted group-hover:text-accent transition-colors truncate">
            {handle}
          </span>
        </a>
      </li>
    ))}
  </ul>
</section>
