---
// Newsletter signup form — posts to Buttondown.
---

<section class="py-12">
  <div class="scroll-reveal rounded-xl border border-default bg-elevated p-6 sm:p-8 transition-all duration-300 hover:border-accent">
    <div class="flex items-start gap-3 mb-2">
      <!-- tiny cat envelope icon -->
      <svg class="h-5 w-5 shrink-0 text-accent mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="4" width="20" height="16" rx="2" />
        <path d="m22 7-10 7L2 7" />
        <!-- cat ears on the envelope flap -->
        <path d="M6 4 L4 1 L8 3.5" fill="currentColor" stroke="none" />
        <path d="M18 4 L20 1 L16 3.5" fill="currentColor" stroke="none" />
      </svg>
      <h2 class="font-serif text-2xl font-semibold">stay in the loop</h2>
    </div>

    <p class="text-sm text-muted mb-5 max-w-prose">
      Get notified when I publish something new — posts, projects, or the occasional cat photo. No spam, unsubscribe anytime.
    </p>

    <!-- Signup form -->
    <form
      id="newsletter-form"
      action="https://buttondown.com/api/emails/embed-subscribe/rainxchzed"
      method="POST"
      target="_blank"
      class="newsletter-form"
    >
      <input type="hidden" name="tag" value="website" />

      <div class="flex flex-col sm:flex-row gap-3">
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input
          id="newsletter-email"
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          autocomplete="email"
          class="flex-1 rounded-lg border border-default bg-bg px-4 py-2.5 text-sm text-fg placeholder:text-muted/60 outline-none transition-colors duration-200 focus:border-accent focus:ring-1 focus:ring-accent/30"
        />
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent-soft px-5 py-2.5 text-sm font-medium text-accent transition-all duration-200 hover:bg-[rgb(var(--accent)/0.2)] active:scale-[0.97] cursor-pointer"
        >
          <!-- small paw icon -->
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <circle cx="7" cy="5" r="3" />
            <circle cx="17" cy="5" r="3" />
            <circle cx="3.5" cy="12" r="2.5" />
            <circle cx="20.5" cy="12" r="2.5" />
            <path d="M12 22c-4 0-7-3-7-6.5C5 12 8.5 10 12 10s7 2 7 5.5c0 3.5-3 6.5-7 6.5z" />
          </svg>
          subscribe
        </button>
      </div>
    </form>

    <!-- Success message (hidden by default) -->
    <div id="newsletter-success" class="newsletter-success hidden mt-4 flex items-center gap-2 text-sm text-accent">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 6 9 17l-5-5" />
      </svg>
      <span>purrfect — check your inbox to confirm!</span>
    </div>
  </div>
</section>

<script>
  function initNewsletterForm() {
    const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
    const success = document.getElementById('newsletter-success');

    if (!form || !success) return;

    // Reset state on each page load (view transitions)
    success.classList.add('hidden');
    form.classList.remove('hidden');

    // Remove any previous listener by cloning the node
    const freshForm = form.cloneNode(true) as HTMLFormElement;
    form.parentNode?.replaceChild(freshForm, form);
    freshForm.id = 'newsletter-form';

    freshForm.addEventListener('submit', () => {
      // Show success message after a brief delay (form opens in new tab)
      setTimeout(() => {
        success.classList.remove('hidden');
        success.classList.add('animate-fade-up');
      }, 400);
    });
  }

  // Init on first load
  initNewsletterForm();

  // Re-init after view transitions
  document.addEventListener('astro:page-load', initNewsletterForm);
</script>
