---
// Full-text search modal powered by Pagefind.
// Uses @pagefind/default-ui for the search interface, themed to match
// the site's CSS-variable-driven design system.
---

<button
  id="search-trigger"
  type="button"
  aria-label="Search"
  class="relative inline-flex h-9 w-9 items-center justify-center rounded-full border border-default bg-elevated text-fg transition-colors hover:text-accent hover:border-accent"
>
  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="8"></circle>
    <path d="M21 21l-4.35-4.35"></path>
  </svg>
</button>

<dialog
  id="search-dialog"
  class="search-dialog"
>
  <div class="search-dialog-inner" id="search-dialog-inner">
    <div class="search-dialog-header">
      <div id="search-container"></div>
      <button
        id="search-close"
        type="button"
        aria-label="Close search"
        class="search-close-btn"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <p class="search-dev-note" id="search-dev-note" hidden>
      Search is available after building the site for production.
    </p>
  </div>
</dialog>

<style>
  /* ---- Dialog chrome ---- */
  .search-dialog {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
    margin: 0;
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    border: none;
    background: transparent;
    color: rgb(var(--fg));
  }

  .search-dialog:not([open]) {
    display: none;
  }

  .search-dialog::backdrop {
    background: rgb(var(--bg) / 0.6);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .search-dialog-inner {
    position: relative;
    width: 100%;
    max-width: 36rem;
    max-height: 70vh;
    margin-inline: 1rem;
    display: flex;
    flex-direction: column;
    border-radius: 0.75rem;
    border: 1px solid rgb(var(--border));
    background-color: rgb(var(--bg-elevated));
    box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25);
    overflow: hidden;
  }

  .search-dialog-header {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 1rem 1rem 0;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    flex-direction: column;
  }

  #search-container {
    width: 100%;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .search-close-btn {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    border: 1px solid rgb(var(--border));
    background: rgb(var(--bg-elevated));
    color: rgb(var(--muted));
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  .search-close-btn:hover {
    color: rgb(var(--accent));
    border-color: rgb(var(--accent));
  }

  .search-dev-note {
    padding: 1rem;
    text-align: center;
    color: rgb(var(--muted));
    font-size: 0.875rem;
    font-family: var(--font-sans);
  }

  /* ---- Pagefind Default UI overrides ---- */

  /* Root wrapper */
  #search-container :global(.pagefind-ui) {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: rgb(var(--accent));
    --pagefind-ui-text: rgb(var(--fg));
    --pagefind-ui-background: rgb(var(--bg-elevated));
    --pagefind-ui-border: rgb(var(--border));
    --pagefind-ui-tag: rgb(var(--accent) / 0.12);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.5rem;
    --pagefind-ui-image-border-radius: 0.375rem;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: var(--font-sans);
    font-family: var(--font-sans);
  }

  /* Search input */
  #search-container :global(.pagefind-ui__search-input) {
    background-color: rgb(var(--bg));
    color: rgb(var(--fg));
    border: 1px solid rgb(var(--border));
    border-radius: 0.5rem;
    font-family: var(--font-sans);
    padding-right: 2.5rem;
  }

  #search-container :global(.pagefind-ui__search-input:focus) {
    outline: none;
    border-color: rgb(var(--accent));
    box-shadow: 0 0 0 2px rgb(var(--accent) / 0.2);
  }

  #search-container :global(.pagefind-ui__search-input::placeholder) {
    color: rgb(var(--muted));
  }

  /* Clear button */
  #search-container :global(.pagefind-ui__search-clear) {
    color: rgb(var(--muted));
    background: none;
    right: 0.25rem;
  }

  #search-container :global(.pagefind-ui__search-clear:focus) {
    outline-color: rgb(var(--accent));
  }

  /* Results container */
  #search-container :global(.pagefind-ui__results-area) {
    margin-top: 0.5rem;
    overflow-y: auto;
    max-height: calc(70vh - 6rem);
    padding: 0 0 1rem;
  }

  /* Individual results */
  #search-container :global(.pagefind-ui__result) {
    border-top-color: rgb(var(--border));
    padding: 0.75rem 0;
  }

  #search-container :global(.pagefind-ui__result-link) {
    color: rgb(var(--fg));
    font-weight: 600;
    text-decoration: none;
    font-family: var(--font-sans);
  }

  #search-container :global(.pagefind-ui__result-link:hover) {
    color: rgb(var(--accent));
  }

  #search-container :global(.pagefind-ui__result-excerpt) {
    color: rgb(var(--muted));
    font-size: 0.875rem;
    line-height: 1.5;
  }

  #search-container :global(mark) {
    background-color: rgb(var(--accent) / 0.2);
    color: rgb(var(--fg));
    border-radius: 2px;
    padding: 0 2px;
  }

  /* Message text (e.g. "No results found") */
  #search-container :global(.pagefind-ui__message) {
    color: rgb(var(--muted));
    font-family: var(--font-sans);
    padding: 1rem 0;
  }

  /* Result tags / sub-results */
  #search-container :global(.pagefind-ui__result-tag) {
    color: rgb(var(--accent));
    background: rgb(var(--accent) / 0.12);
    border-radius: 0.25rem;
    padding: 0.1rem 0.4rem;
    font-size: 0.75rem;
  }

  /* Button styling */
  #search-container :global(.pagefind-ui__button) {
    color: rgb(var(--fg));
    background: rgb(var(--bg));
    border: 1px solid rgb(var(--border));
    border-radius: 0.5rem;
    font-family: var(--font-sans);
  }

  #search-container :global(.pagefind-ui__button:hover) {
    border-color: rgb(var(--accent));
    color: rgb(var(--accent));
  }

  /* Hide the Pagefind form wrapper border — we provide our own chrome */
  #search-container :global(.pagefind-ui__form) {
    border: none;
    padding: 0;
  }

  /* Drawer / results area scrollbar */
  #search-container :global(.pagefind-ui__results-area)::-webkit-scrollbar {
    width: 6px;
  }

  #search-container :global(.pagefind-ui__results-area)::-webkit-scrollbar-track {
    background: transparent;
  }

  #search-container :global(.pagefind-ui__results-area)::-webkit-scrollbar-thumb {
    background: rgb(var(--border));
    border-radius: 3px;
  }

  /* Thumbnails — hide if the site doesn't produce them */
  #search-container :global(.pagefind-ui__result-thumb) {
    display: none;
  }
</style>

<script>
  function initSearch() {
    const trigger = document.getElementById('search-trigger') as HTMLButtonElement | null;
    const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
    const closeBtn = document.getElementById('search-close') as HTMLButtonElement | null;
    const container = document.getElementById('search-container') as HTMLDivElement | null;
    const devNote = document.getElementById('search-dev-note') as HTMLParagraphElement | null;

    if (!trigger || !dialog || !closeBtn || !container) return;

    // Prevent double-binding after view transitions
    if (trigger.dataset.bound === 'true') return;
    trigger.dataset.bound = 'true';

    let pagefindUI: any = null;

    async function loadPagefind(): Promise<void> {
      if (pagefindUI) return;

      // If PagefindUI was already loaded by a previous navigation
      if ((window as any).PagefindUI) {
        pagefindUI = new (window as any).PagefindUI({
          element: container,
          showSubResults: true,
          showImages: false,
          resetStyles: false,
        });
        if (devNote) devNote.hidden = true;
        return;
      }

      // Load Pagefind UI via script injection (NOT import()) so Vite
      // doesn't try to resolve /pagefind/* at build time — those files
      // are generated post-build by the `pagefind` CLI.
      return new Promise<void>((resolve) => {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = '/pagefind/pagefind-ui.css';
        document.head.appendChild(link);

        const script = document.createElement('script');
        script.src = '/pagefind/pagefind-ui.js';
        script.onload = () => {
          pagefindUI = new (window as any).PagefindUI({
            element: container,
            showSubResults: true,
            showImages: false,
            resetStyles: false,
          });
          if (devNote) devNote.hidden = true;
          resolve();
        };
        script.onerror = () => {
          // Pagefind bundle not found — likely dev mode
          if (devNote) devNote.hidden = false;
          resolve();
        };
        document.head.appendChild(script);
      });
    }

    function openDialog() {
      dialog.showModal();
      loadPagefind().then(() => {
        // Auto-focus the search input inside Pagefind UI
        const input = container.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
        if (input) {
          input.focus();
          input.select();
        }
      });
    }

    function closeDialog() {
      dialog.close();
    }

    // Trigger button
    trigger.addEventListener('click', openDialog);

    // Close button
    closeBtn.addEventListener('click', closeDialog);

    // Click on backdrop (the dialog element outside the inner panel) to close
    dialog.addEventListener('click', (e: MouseEvent) => {
      if (e.target === dialog) closeDialog();
    });

    // Cmd+K / Ctrl+K shortcut
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (dialog.open) {
          closeDialog();
        } else {
          openDialog();
        }
      }
    });
  }

  // Run on initial load and after every view-transition navigation
  initSearch();
  document.addEventListener('astro:page-load', initSearch);
</script>
