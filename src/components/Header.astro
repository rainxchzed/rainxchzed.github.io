---
import ScrollProgress from './ScrollProgress.astro';
import Search from './Search.astro';
import ThemeToggle from './ThemeToggle.astro';

const nav = [
  { label: 'home', href: '/' },
  { label: 'posts', href: '/posts' },
];

const current = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return current === '/';
  return current === href || current.startsWith(href + '/');
}
---

<ScrollProgress />
<header class="sticky top-0 z-40 backdrop-blur-md border-b border-default" style="background-color: rgb(var(--bg) / 0.72);">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-4 flex items-center justify-between gap-3">
    <a
      href="/"
      class="group flex items-center gap-2 font-serif text-base sm:text-lg font-semibold tracking-tight text-fg hover:text-accent transition-colors min-w-0"
    >
      <!-- Tiny cat head icon -->
      <svg class="h-6 w-6 shrink-0" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
        <path d="M6 6l4 6h12l4-6v13a10 10 0 0 1-10 10h-0a10 10 0 0 1-10-10V6z"/>
        <circle cx="12" cy="17" r="1.2" fill="rgb(var(--bg))"/>
        <circle cx="20" cy="17" r="1.2" fill="rgb(var(--bg))"/>
        <path d="M14.5 21c.6.6 2.4.6 3 0" fill="none" stroke="rgb(var(--bg))" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <span class="truncate">rainxchzed</span>
    </a>

    <nav class="flex items-center gap-4 sm:gap-6 shrink-0">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            'text-sm transition-colors hover:text-accent nav-underline',
            isActive(href) ? 'text-accent' : 'text-muted',
          ]}
        >
          {label}
        </a>
      ))}
      <Search />
      <ThemeToggle />
    </nav>
  </div>
</header>
