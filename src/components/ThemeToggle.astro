---
// Dark / light toggle button with a circular reveal animation via the
// View Transitions API — falls back to an instant swap where unsupported.
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle color theme"
  class="relative inline-flex h-9 w-9 items-center justify-center rounded-full border border-default bg-elevated text-fg transition-colors hover:text-accent hover:border-accent"
>
  <!-- Sun: shown in dark mode (click to go light) -->
  <svg class="theme-icon-sun h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
  </svg>
  <!-- Moon: shown in light mode (click to go dark) -->
  <svg class="theme-icon-moon h-4 w-4 absolute" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<style>
  .theme-icon-sun { display: none; }
  .theme-icon-moon { display: block; }
  :global(.dark) .theme-icon-sun { display: block; }
  :global(.dark) .theme-icon-moon { display: none; }
</style>

<script>
  function setupThemeToggle() {
    const button = document.getElementById('theme-toggle') as HTMLButtonElement | null;
    if (!button || button.dataset.bound === 'true') return;
    button.dataset.bound = 'true';

    button.addEventListener('click', (event) => {
      const willBeDark = !document.documentElement.classList.contains('dark');

      const apply = () => {
        document.documentElement.classList.toggle('dark', willBeDark);
        try {
          localStorage.setItem('theme', willBeDark ? 'dark' : 'light');
        } catch (_) {}
      };

      // Feature-detect the View Transitions API for circular reveal
      const anyDoc = document as Document & {
        startViewTransition?: (cb: () => void) => {
          ready: Promise<void>;
          finished: Promise<void>;
        };
      };

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!anyDoc.startViewTransition || prefersReduced) {
        apply();
        return;
      }

      const x = event.clientX;
      const y = event.clientY;
      const endRadius = Math.hypot(
        Math.max(x, window.innerWidth - x),
        Math.max(y, window.innerHeight - y),
      );

      const transition = anyDoc.startViewTransition(apply);
      transition.ready.then(() => {
        document.documentElement.animate(
          {
            clipPath: [
              `circle(0 at ${x}px ${y}px)`,
              `circle(${endRadius}px at ${x}px ${y}px)`,
            ],
          },
          {
            duration: 520,
            easing: 'cubic-bezier(0.16, 1, 0.3, 1)',
            pseudoElement: willBeDark
              ? '::view-transition-new(root)'
              : '::view-transition-old(root)',
          },
        );
      });
    });
  }

  setupThemeToggle();
  document.addEventListener('astro:page-load', setupThemeToggle);
</script>
